# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ── Build outputs ─────────────────────────────────────────────────────────────
# Rust / Soroban
contracts/target/

# Next.js
ui/.next/
ui/out/

# Circuit compilation artifacts
circuits/build/

# Generated contract bindings — tsc output (regenerate with `bun run bindings`).
# The package source (bindings/src) is committed; the build is not.
bindings/dist/

# ── Circuit runtime artifacts (copied to ui/public/ — must be built, not committed) ──
ui/public/main.wasm
ui/public/main.zkey
ui/public/verification_key.json

# ── Environment & secrets ─────────────────────────────────────────────────────
.env*

# ── Local databases ───────────────────────────────────────────────────────────
*.db
*.sqlite

# ── Stellar / Soroban local state ─────────────────────────────────────────────
.soroban/
.stellar/

# ── TypeScript ────────────────────────────────────────────────────────────────
*.tsbuildinfo
ui/next-env.d.ts

# ── Tooling caches ────────────────────────────────────────────────────────────
.turbo/
coverage/

# ── Debug logs ────────────────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ── OS / Editor ───────────────────────────────────────────────────────────────
.DS_Store
*.pem
.vercel
